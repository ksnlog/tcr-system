# ─── REQUIRED ───────────────────────────────────────────────
# Your deployed Vercel URL (no trailing slash)
# Example: https://tcr-system.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-app-name.vercel.app

# ─── OPTIONAL: Vercel KV (recommended for production) ───────
# Create at: Vercel Dashboard → Storage → KV
# These are auto-populated when you link KV to your project:
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# ─── OPTIONAL: WhatsApp APIs (pick one) ─────────────────────

# Fast2SMS (India) — https://fast2sms.com
# FAST2SMS_API_KEY=your_key_here

# MSG91 — https://msg91.com
# MSG91_AUTH_KEY=your_key_here
# MSG91_TEMPLATE_ID=your_template_id

# Twilio WhatsApp Sandbox
# TWILIO_ACCOUNT_SID=your_sid
# TWILIO_AUTH_TOKEN=your_token

# Meta WhatsApp Cloud API — https://developers.facebook.com
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# WHATSAPP_ACCESS_TOKEN=your_permanent_token
